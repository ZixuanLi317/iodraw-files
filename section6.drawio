        <mxCell id="lPkQfJbUEwC9vkQxYqbs-150" parent="1" style="whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#94a3b8;strokeWidth=1.8;fontSize=12;fontColor=#20252b;fontStyle=0;fontFamily=Helvetica;align=center;verticalAlign=middle;spacing=8;rounded=1;arcSize=8;" value="&lt;div style=&quot;line-height:113%;&quot;&gt;&lt;b&gt;Planning and governance interpretation&lt;/b&gt;&lt;br&gt;&lt;div style=&quot;line-height:113%;&quot;&gt;&lt;ul style=&quot;margin-bottom: 4px; padding-left: 10px; margin-top: 4px;&quot;&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Prioritise support for the U1–U2 mismatch cluster&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;Reduce over-reliance on the U3 dependency hub&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Use allocation to improve&amp;nbsp;&lt;/span&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;local support deficits&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Use reconfiguration to reduce&amp;nbsp;&lt;/span&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;lag and dependency risks&lt;/font&gt;&lt;/li&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;font-size: 10px;&quot;&gt;Interpret reliability and fairness&amp;nbsp;&lt;/span&gt;&lt;font style=&quot;font-size: 10px;&quot;&gt;together, because stronger technological coordination can improve EO1 while worsening EO2&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;/div&gt;" vertex="1">
