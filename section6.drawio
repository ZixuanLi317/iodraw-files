&gt;&lt;div style=&quot;font-size: 10px; text-align: left;&quot;&gt;&lt;b&gt;&lt;br&gt;&lt;/b&gt;&lt;/div&gt;&lt;div style=&quot;font-size: 10px; text-align: left; line-height: 102%;&quot;&gt;&lt;b&gt;Read-out:&amp;nbsp;&lt;/b&gt;&lt;/div&gt;&lt;div&gt;&lt;div&gt;&lt;div&gt;&lt;ul style=&quot;padding-left: 10px; margin-top: 3px; margin-bottom: 3px;&quot;&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 9px; line-height: 102%;&quot;&gt;&lt;i&gt;H1&lt;/i&gt; explains SE1:&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;span style=&quot;font-size: 8px; background-color: transparent; color: light-dark(rgb(32, 37, 43), rgb(201, 206, 211)); line-height: 102%;&quot;&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(32, 37, 43), rgb(201, 206, 211)); line-height: 112%;&quot;&gt;U1--U2 mismatch via local demand-support imbalance&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(32, 37, 43), rgb(201, 206, 211)); line-height: 112%;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;/span&gt;&lt;ul style=&quot;padding-left: 10px; margin-top: 3px; margin-bottom: 0px;&quot;&gt;&lt;li style=&quot;text-align: left;&quot;&gt;&lt;font style=&quot;font-size: 9px; line-height: 102%;&quot;&gt;&lt;i&gt;H2&lt;/i&gt; explains SE1 persistence:&lt;/font&gt;&lt;/li&gt;&lt;/ul&gt;&lt;/div&gt;&lt;div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(32, 37, 43), rgb(201, 206, 211)); font-size: 8px; line-height: 102%;&quot;&gt;mismatch amplified by delayed T→E support&lt;/span&gt;&lt;/div&gt;&lt;div style=&quot;text-align: left;&quot;&gt;&lt;span style=&quot;background-color: transparent; color: light-dark(rgb(32, 37, 43), rgb(201, 206, 211)); font-size: 8px; line-height: 102%;&quot;&gt;&lt;br&gt;&lt;/span&gt;&lt;/div&gt;&lt;ul style=&quot